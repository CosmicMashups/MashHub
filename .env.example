# Supabase (replace with your project values)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Public site URL for auth (signup confirmation, magic link redirect).
# Local dev: use http://localhost:5173 (or your Vite port). Must match Supabase redirect allow-list.
# Production / CI: use your real origin, e.g. https://<owner>.github.io/MashHub — NOT localhost,
# or confirmation emails can contain localhost links. Omit in CI to rely on runtime origin;
# the app also ignores localhost env when opened from a non-local host.
VITE_SITE_URL=http://localhost:5173
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# Backend/scripts only - NEVER expose in frontend bundle
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
